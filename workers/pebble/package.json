{
  "name": "@repo/pebble-worker",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "wrangler dev --remote",
    "deploy:cf": "pnpm run cf-typegen && wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "typecheck": "pnpm run cf-typegen && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.4.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@repo/db": "workspace:*",
    "agents": "^0.9.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "typescript": "^6.0.2",
    "vitest": "^3.2.4",
    "wrangler": "^4.4.0"
  }
}
