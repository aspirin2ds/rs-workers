{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "deploy": {
      "dependsOn": ["^build", "cf-typegen"],
      "cache": false
    },
    "cf-typegen": {
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["^build", "cf-typegen"]
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate:local": {
      "cache": false
    },
    "db:migrate:remote": {
      "cache": false
    }
  }
}
