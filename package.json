{
  "name": "maid-workers",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "dev:auth": "pnpm --filter @repo/auth-worker dev",
    "dev:maid": "pnpm --filter @repo/maid-worker dev",
    "deploy": "turbo deploy:cf",
    "deploy:auth": "pnpm --filter @repo/auth-worker deploy:cf",
    "deploy:maid": "pnpm --filter @repo/maid-worker deploy:cf",
    "cli": "pnpm --filter @repo/cli start",
    "test": "turbo test",
    "test:watch": "turbo test:watch",
    "typecheck": "turbo typecheck",
    "db:generate": "turbo db:generate",
    "db:migrate:local": "turbo db:migrate:local",
    "db:migrate:remote": "turbo db:migrate:remote"
  },
  "devDependencies": {
    "turbo": "^2"
  },
  "packageManager": "pnpm@10.28.2"
}
