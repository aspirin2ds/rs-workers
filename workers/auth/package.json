{
  "name": "@repo/auth-worker",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "wrangler dev --remote",
    "deploy:cf": "pnpm run cf-typegen && wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "typecheck": "tsc --noEmit",
    "auth:schema": "pnpm dlx @better-auth/cli@latest generate --config ./better-auth.config.ts --output ../../packages/db/src/schema.ts"
  },
  "dependencies": {
    "@repo/db": "workspace:*",
    "better-auth": "^1.6.3",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.9",
    "jose": "^6.2.2",
    "resend": "^6.10.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2",
    "wrangler": "^4.4.0"
  }
}
