    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@repo/db": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2",
    "wrangler": "^4.4.0"
  }
}
